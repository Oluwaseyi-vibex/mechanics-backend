{
  "info": {
    "name": "Mechanics API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Auth + Interswitch Payments API"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "interswitch_client_id",
      "value": ""
    },
    {
      "key": "interswitch_client_secret",
      "value": ""
    },
    {
      "key": "interswitch_access_token",
      "value": ""
    },
    {
      "key": "last_transaction_ref",
      "value": ""
    },
    {
      "key": "last_payment_id",
      "value": ""
    },
    {
      "key": "last_amount",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"Demo Ventures\",\n  \"email\": \"owner@example.com\",\n  \"phone\": \"08012345678\",\n  \"password\": \"password123\",\n  \"meterNumber\": \"12345678901\",\n  \"disco\": \"ikedc\",\n  \"meterType\": \"prepaid\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
        ,
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email?token=PASTE_TOKEN",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"],
              "query": [
                { "key": "token", "value": "PASTE_TOKEN" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Purchase",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/purchase",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "purchase"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meterNumber\": \"12345678901\",\n  \"amount\": 10000,\n  \"currency\": \"NGN\",\n  \"authData\": \"encrypted_card_data_here\",\n  \"transactionRef\": \"optional_ref_001\",\n  \"customerId\": \"optional_customer_id\",\n  \"merchantCode\": \"MX12345\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.interswitch?.paymentId) {",
                  "  pm.collectionVariables.set('last_payment_id', json.interswitch.paymentId);",
                  "}",
                  "if (json?.interswitch?.transactionRef) {",
                  "  pm.collectionVariables.set('last_transaction_ref', json.interswitch.transactionRef);",
                  "}",
                  "if (json?.transaction?.amount) {",
                  "  pm.collectionVariables.set('last_amount', json.transaction.amount);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate Auth Data",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/auth-data",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "auth-data"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pan\": \"5060990580000217499\",\n  \"pin\": \"1111\",\n  \"expiryYYMM\": \"2004\",\n  \"cvv2\": \"111\"\n}"
            }
          }
        },
        {
          "name": "Store Auth Data",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/auth-data/store",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "auth-data", "store"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authData\": \"encrypted_card_data_here\"\n}"
            }
          }
        },
        {
          "name": "Set Topup Amount",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/topup-amount",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "topup-amount"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 10000\n}"
            }
          }
        },
        {
          "name": "Generate Access Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "token"]
            }
          }
        },
        {
          "name": "Interswitch Token (Direct)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "url": {
              "raw": "https://sandbox.interswitchng.com/passport/oauth/token?grant_type=client_credentials",
              "protocol": "https",
              "host": ["sandbox", "interswitchng", "com"],
              "path": ["passport", "oauth", "token"],
              "query": [
                { "key": "grant_type", "value": "client_credentials" }
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "client_credentials" }
              ]
            },
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "{{interswitch_client_id}}", "type": "string" },
                { "key": "password", "value": "{{interswitch_client_secret}}", "type": "string" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.access_token) {",
                  "  pm.collectionVariables.set('interswitch_access_token', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "OTP Verify",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/otp",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "otp"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{last_payment_id}}\",\n  \"otp\": \"123456\",\n  \"transactionId\": \"{{last_payment_id}}\",\n  \"eciFlag\": \"07\",\n  \"transactionRef\": \"{{last_transaction_ref}}\"\n}"
            }
          }
        },
        {
          "name": "Transaction Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/status?transactionreference={{last_transaction_ref}}&amount={{last_amount}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "status"],
              "query": [
                { "key": "transactionreference", "value": "{{last_transaction_ref}}" },
                { "key": "amount", "value": "{{last_amount}}" }
              ]
            }
          }
        }
        ,
        {
          "name": "Get Transaction By ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/{{last_transaction_ref}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "{{last_transaction_ref}}"]
            }
          }
        }
        ,
        {
          "name": "Mark Transaction Failed",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/payments/{{last_transaction_ref}}/mark-failed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payments", "{{last_transaction_ref}}", "mark-failed"]
            }
          }
        }
      ]
    },
    {
      "name": "Meters",
      "item": [
        {
          "name": "List Meters",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/meters",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meters"]
            }
          }
        },
        {
          "name": "Get Meter By Number",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/meters/12345678901",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meters", "12345678901"]
            }
          }
        },
        {
          "name": "Update Meter Config",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/meters/12345678901/config",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meters", "12345678901", "config"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentCode\": \"051758901\",\n  \"billerCode\": \"051758901\"\n}"
            }
          }
        },
        {
          "name": "Apply QA Electricity Test Data",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/meters/12345678901/apply-qa-electricity",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meters", "12345678901", "apply-qa-electricity"]
            }
          }
        },
        {
          "name": "Validate Meter (VTpass)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/meters/validate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meters", "validate"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meterNumber\": \"1111111111111\",\n  \"disco\": \"ikedc\",\n  \"type\": \"prepaid\"\n}"
            }
          }
        },
        {
          "name": "Validate IKEDC Meter",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/meters/validate/ikedc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "meters", "validate", "ikedc"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meterNumber\": \"1111111111111\",\n  \"type\": \"prepaid\"\n}"
            }
          }
        }
      ]
    }
    ,
    {
      "name": "IoT (Mock)",
      "item": [
        {
          "name": "Credit Update",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/iot/credit-update",
              "host": ["{{baseUrl}}"],
              "path": ["api", "iot", "credit-update"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meterNumber\": \"12345678901\",\n  \"creditLevel\": 10\n}"
            }
          }
        }
      ]
    }
  ]
}
